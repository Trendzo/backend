# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://closetx:closetx@localhost:5432/closetx_dev

# --- Auth ---
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_CONSUMER_ACCESS_EXPIRES_IN=30d

# --- MSG91 (phone-OTP login) ---
# Server-side account authkeys used to verify OTP-widget access tokens. The widgets'
# public widgetId/tokenAuth pairs live in the mobile app config, not here.
# Consumer and retailer widgets are under SEPARATE MSG91 accounts, so each needs its
# own account authkey — a token from one account only verifies against that account's key.
MSG91_AUTH_KEY=          # consumer widget's account authkey
MSG91_RETAILER_AUTH_KEY= # retailer widget's account authkey

# --- Public App Store legal/support pages ---
PUBLIC_APP_NAME=Trendzo Mockup
PUBLIC_COMPANY_NAME=Trendzo
PUBLIC_SUPPORT_EMAIL=trendzodevelopment@gmail.com
# PUBLIC_SUPPORT_PHONE=+91...
# PUBLIC_BUSINESS_ADDRESS=Your registered business address

# --- Media storage ---
# Which backend uploads go to. 'cloudinary' is the legacy provider, 's3' is our own
# bucket, 'memory' is the in-process fake the test suite uses. Flipping this is the
# migration switch and the rollback lever — no code change needed.
STORAGE_DRIVER=cloudinary

# Cloudinary (legacy). Uploads 503 when STORAGE_DRIVER=cloudinary and these are unset.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3. Uploads 503 when STORAGE_DRIVER=s3 and bucket/base-url are unset.
# S3_PUBLIC_BASE_URL is the CloudFront domain in front of the bucket — the bucket
# itself blocks all public access, so this is the only path to a readable asset.
S3_BUCKET=
AWS_REGION=ap-south-1
S3_PUBLIC_BASE_URL=
# Key namespace so one bucket serves dev/staging/prod. Leave empty in production.
S3_KEY_PREFIX=dev
# Leave the credentials unset in AWS-hosted environments — the SDK's default provider
# chain picks up the task/instance role, which beats long-lived keys. Local dev only.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Payment gateway (defer; sandbox keys) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- AI catalog provider (defer; vendor TBD) ---
# AI_CATALOG_PROVIDER_URL=
# AI_CATALOG_PROVIDER_KEY=

# --- GST ---
TCS_RATE_BP=100

# --- CORS (production) ---
# Comma-separated origin allowlist for cross-origin browser requests. Only used when
# NODE_ENV=production. In development, all origins are allowed automatically.
# Example:
#   CORS_ORIGIN=https://closetx-frontend.vercel.app,https://admin.closetx.in
CORS_ORIGIN=
